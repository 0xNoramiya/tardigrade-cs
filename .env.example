# TrueFoundry AI Gateway
TFY_API_KEY=
TFY_HOST=https://your-tenant.truefoundry.cloud
TFY_GATEWAY_BASE_URL=https://your-tenant.truefoundry.cloud/api/llm/openai/v1

# Virtual Model name configured in TrueFoundry (matches gateway-config/)
TARDIGRADE_PRIMARY_MODEL=tardigrade-primary/tardigrade-primary

# TrueFoundry MCP Gateway endpoint (Virtual MCP Server)
TFY_MCP_GATEWAY_URL=

# Optional: AWS Bedrock direct (only if not using TF gateway for Bedrock)
AWS_REGION=us-east-1

# Embeddings tier
TARDIGRADE_FAQ_PATH=data/faq.json
TARDIGRADE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
TARDIGRADE_EMBEDDING_THRESHOLD=0.55

# Chaos engine — set to 1 in production to disable chaos rewrites entirely
TARDIGRADE_DISABLE_CHAOS=0
